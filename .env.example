# === Public (client-side accessible) ===
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NUXT_PUBLIC_AUTH_BASE_URL=http://localhost:3000
NUXT_PUBLIC_GA_ID=

# Google AdSense (PC 웹 배너 전용. 모바일 앱은 AdMob 사용)
# AdSense 승인 받기 전에는 비워둠 — 빈 placeholder 도 노출 안 됨.
NUXT_PUBLIC_ADSENSE_CLIENT=
NUXT_PUBLIC_ADSENSE_SLOT=

# Google AdMob (Android 앱 전용. dev 빌드는 capacitor.config 의
# initializeForTesting=true 로 Google 테스트 광고 ID 자동 사용)
# 출시 빌드 시 실제 광고 단위 ID 입력. AdMob 콘솔에서 발급.
# https://apps.admob.com
NUXT_PUBLIC_ADMOB_REWARDED_AD_ID=

# === Server-only (never exposed to client) ===

# Shared dev PG. search_path=auth,public lets better-auth store its
# tables in the `auth` schema while still being able to query
# `public.users` from the `definePayload` hook.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/TERA_WORLD?search_path=auth,public

# better-auth server secret. Used to sign session cookies and to
# encrypt private RSA keys stored in auth.jwks. This is NOT shared with
# the Spring backend — Spring verifies JWTs via the JWKS public keys
# only. Generate with `openssl rand -hex 32` (32+ chars).
BETTER_AUTH_SECRET=replace-with-better-auth-cookie-signing-secret
BETTER_AUTH_URL=http://localhost:3000

# Internal token shared with the Spring backend. better-auth
# `databaseHooks.user.create.after` calls Spring's internal bootstrap
# endpoint with this token in the `X-Internal-Token` header.
# MUST match backend INTERNAL_API_TOKEN exactly. Transferred out-of-band.
INTERNAL_API_TOKEN=replace-with-shared-internal-token-32-chars
INTERNAL_API_BASE_URL=http://localhost:8080
