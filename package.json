{
  "name": "terraworld-frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "typecheck": "nuxi typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:init": "psql \"$DATABASE_URL\" -f server/db/migrations/001_better_auth_init.sql",
    "db:verify": "psql \"$DATABASE_URL\" -c \"\\dt auth.*\""
  },
